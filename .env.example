APP_ENV=local
APP_DEBUG=true
APP_PORT=8000

MYSQL_ROOT_PASSWORD=rootsecret

DB_HOST=db
DB_PORT=3306
DB_NAME=app
DB_USER=app
DB_PASSWORD=secret

JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=3600

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_MAX_AGE=86400

STORAGE_PATH=/var/www/html/storage
STORAGE_MAX_UPLOAD_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
IMAGE_MAX_DIMENSION=1920
IMAGE_THUMBNAIL_DIMENSION=300
IMAGE_WEBP_QUALITY=80

PAYWAY_MOCK=true
PAYWAY_MERCHANT_ID=
PAYWAY_PUBLIC_KEY=
PAYWAY_CHECKOUT_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/purchase
PAYWAY_SUCCESS_URL=http://localhost:5173/orders/{orderId}?paid=1
PAYWAY_WEBHOOK_URL=http://localhost:8000/api/webhooks/payway
